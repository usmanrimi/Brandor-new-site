generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = "postgresql://postgres.jxzdrnnxxctdbefpouds:Br%40ndor0123%40@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
  directUrl = "postgresql://postgres.jxzdrnnxxctdbefpouds:Br%40ndor0123%40@aws-0-eu-north-1.pooler.supabase.com:5432/postgres"
}

model Project {
  id          String   @id @default(cuid())
  title       String
  client      String
  category    String
  date        String
  location    String
  description String
  images      String   // Stored as JSON string array of URLs
  videoUrl    String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  author      String
  imageUrl    String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String
  company     String
  content     String
  imageUrl    String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String
  websiteUrl  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String
  bio         String?
  imageUrl    String
  twitterUrl  String?
  linkedinUrl String?
  createdAt   DateTime @default(now())
}

model Setting {
  id          String   @id @default("global")
  siteName    String   @default("Brandor")
  siteDesc    String   @default("Premium Media Documentation")
  email       String   @default("hello@brandor.com")
  whatsapp    String   @default("+1234567890")
  address     String   @default("Kano State, Nigeria")
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String   // Icon name for lucide-react
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MediaAsset {
  id          String   @id @default(cuid())
  name        String
  url         String
  type        String   @default("image") // image, video, document
  size        Int      @default(0)
  category    String?
  createdAt   DateTime @default(now())
}

model AboutContent {
  id          String   @id @default("global")
  aboutText   String   @default("Brandor is a creative branding, media production, and storytelling agency...")
  mission     String   @default("To empower brands, organizations, and communities...")
  vision      String   @default("To become Africa's leading creative agency...")
  coreValues  String   // JSON string of {title, description} objects
  process     String   // JSON string of {step, title, description} objects
  whyUs       String   // JSON string of {title, description} objects
  updatedAt   DateTime @updatedAt
}

model HomeContent {
  id          String   @id @default("global")
  heroEyebrow String   @default("Kano · Creative Media Agency")
  heroHeadline String  @default("Every program has a story. We open the door to tell it.")
  heroLead    String   @default("Brandor is a creative media and branding team helping NGOs...")
  ctaText1    String   @default("Book a Project")
  ctaLink1    String   @default("/contact")
  ctaText2    String   @default("Explore Services")
  ctaLink2    String   @default("/services")
  marqueeText String   @default("Branding, Storytelling, Documentation, Media Production, Creative Direction, Strategy")
  updatedAt   DateTime @updatedAt
}
